<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gongdae.app.mapper.BannerMapper">

	<select id="getBanners" resultType="com.gongdae.app.domain.dto.BannerDto">
		SELECT 
    		banner_no, save_filename, link_url
    	FROM banner
    	WHERE is_active = 1
	</select>
	
</mapper>